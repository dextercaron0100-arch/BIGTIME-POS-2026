NODE_ENV=development
PORT=3000
APP_HOST=127.0.0.1

# Security
JWT_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_ALLOW_DEMO_USERS=false

# Storage
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apex_pos?schema=public
REDIS_URL=redis://localhost:6379

# HTTP / CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
REQUEST_BODY_LIMIT=10mb
ENABLE_SWAGGER=true

# EIS (set endpoint + credentials for live filing)
EIS_ALLOW_SIMULATION=false
EIS_ENDPOINT_URL=
EIS_API_KEY=
EIS_TAXPAYER_TIN=
EIS_SIGNING_SECRET=replace-with-at-least-32-characters
EIS_MAX_RETRIES=5
EIS_FLUSH_BATCH_SIZE=50
EIS_RETRY_TICK_MS=15000
